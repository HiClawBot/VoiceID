{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ES2023"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"types": ["vite/client"]
	},
	"include": [
		"src/**/*.ts",
		"vite.config.ts",
		"playwright.config.ts",
		"e2e/**/*.ts"
	]
}
