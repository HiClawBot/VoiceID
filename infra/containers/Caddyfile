{
	admin off
	auto_https off
}

:8080 {
	log {
		output stdout
		format json
	}

	encode zstd gzip

	@api path /v1/* /healthz /readyz /openapi.json
	handle @api {
		request_body {
			max_size 64KB
		}
		reverse_proxy {$AUTH_API_UPSTREAM:auth-api:3401} {
			transport http {
				dial_timeout 3s
				response_header_timeout 15s
			}
		}
	}

	handle {
		root * /srv
		file_server
	}

	@assets path /assets/* *.svg
	header @assets Cache-Control "public, max-age=31536000, immutable"
	header /index.html Cache-Control "no-store"
	header {
		-Server
		Content-Security-Policy "default-src 'self'; base-uri 'none'; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data:; object-src 'none'; script-src 'self'; style-src 'self'"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		Permissions-Policy "camera=(), geolocation=(), microphone=(), payment=(), usb=()"
		Referrer-Policy "no-referrer"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
	}
}
